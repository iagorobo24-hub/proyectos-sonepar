/* Reglas de seguridad de Firestore para SoneparTools */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para verificar autenticación y propiedad
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    // Colección principal de usuarios - cada usuario solo accede a su propio documento
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Subcolecciones dentro del documento de usuario
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Denegar todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
