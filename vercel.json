{
  "buildCommand": "cd app && npm install && npm run build",
  "outputDirectory": "app/dist",
  "functions": {
    "api/anthropic.js": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    {
      "source": "/api/anthropic",
      "destination": "/api/anthropic"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
